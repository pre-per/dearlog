rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== Helpers =====
    function isSignedIn() {
      return request.auth != null;
    }
    function isUser(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ===== 기존: 사용자 본인의 데이터 =====
    // users/{uid} 본문 + 모든 서브컬렉션 (diary, call, etc.)은 본인만 read/write.
    match /users/{userId} {
      allow read, write: if isUser(userId);

      // 일기, 통화 등 본인 소유의 모든 서브컬렉션
      match /{subcollection}/{docId} {
        allow read, write: if isUser(userId);
      }
    }

    // ===== 기존: 피드백 (앱 내 의견 보내기) =====
    // 작성: 로그인한 사용자.
    // 삭제: 본인이 작성한 피드백 (회원탈퇴 시 정리용).
    // 읽기/수정: 운영자(콘솔)만.
    match /feedbacks/{feedbackId} {
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow read, update: if false;
    }

    // ===== 커뮤니티 게시물 =====
    match /community_posts/{postId} {
      // 로그인한 사용자는 모두 읽을 수 있다.
      allow read: if isSignedIn();

      // 작성자 자신만 게시 가능. 카운트 필드는 0 으로 시작해야 한다.
      allow create: if isSignedIn()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.likeCount == 0
        && request.resource.data.commentCount == 0
        && request.resource.data.reportCount == 0
        && request.resource.data.title is string
        && request.resource.data.title.size() < 200
        && request.resource.data.content is string
        && request.resource.data.content.size() < 10000;

      // 업데이트는 두 가지 경로:
      //   (a) 작성자가 본문/이미지 등을 수정 — 단, 식별자/생성시각은 변경 금지
      //   (b) 다른 사용자가 카운트 필드만 증감 (좋아요/댓글/신고 시 FieldValue.increment)
      // (b) 의 카운트는 클라이언트 위변조 위험이 있으므로 v2 에서 Cloud Functions 로 이전 권장.
      allow update: if isSignedIn() && (
        (
          resource.data.authorUid == request.auth.uid
          && request.resource.data.authorUid == resource.data.authorUid
          && request.resource.data.originalDiaryId == resource.data.originalDiaryId
          && request.resource.data.createdAt == resource.data.createdAt
        )
        ||
        (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['likeCount', 'commentCount', 'reportCount'])
        )
      );

      // 삭제는 작성자만.
      allow delete: if isSignedIn() && resource.data.authorUid == request.auth.uid;

      // ----- 댓글 -----
      match /comments/{commentId} {
        allow read: if isSignedIn();

        allow create: if isSignedIn()
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.postId == postId
          && request.resource.data.content is string
          && request.resource.data.content.size() > 0
          && request.resource.data.content.size() < 2000;

        // 댓글 수정은 작성자만, authorUid/postId/createdAt 은 변경 불가.
        allow update: if isSignedIn()
          && resource.data.authorUid == request.auth.uid
          && request.resource.data.authorUid == resource.data.authorUid
          && request.resource.data.postId == resource.data.postId
          && request.resource.data.createdAt == resource.data.createdAt;

        // 댓글 삭제: (a) 댓글 작성자 본인 (b) 게시물 작성자 (자기 글의 댓글 모더레이션).
        allow delete: if isSignedIn() && (
          resource.data.authorUid == request.auth.uid
          || get(/databases/$(database)/documents/community_posts/$(postId)).data.authorUid == request.auth.uid
        );
      }

      // ----- 좋아요 (문서 id == userId) -----
      match /likes/{userId} {
        allow read: if isSignedIn();

        // 본인의 uid 로만 좋아요 생성 가능.
        allow create: if isUser(userId)
          && request.resource.data.userId == userId;

        // 좋아요 취소: 본인 또는 게시물 작성자(게시물 내릴 때 정리용).
        allow delete: if isUser(userId)
          || (isSignedIn()
              && get(/databases/$(database)/documents/community_posts/$(postId)).data.authorUid == request.auth.uid);

        // update 는 사용 안 함
        allow update: if false;
      }
    }

    // ===== 사용자 통계 (랭킹 시스템) =====
    // `user_stats/{uid}` — 사용자의 일기 카운트 / 스트릭 / 최장 기록 등.
    // 커뮤니티 게시물·댓글에서 작성자의 랭크·글로우를 표시하기 위해 로그인한 모든
    // 사용자가 read 가능. write 는 Cloud Functions (Admin SDK) 만 — 클라이언트 위변조
    // 차단. 일기 onWrite 트리거가 단일 진실 공급원.
    match /user_stats/{userId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ===== 신고 =====
    // 작성: 로그인한 사용자가 본인 uid 로.
    // 읽기: 본인이 작성한 신고만.
    // 삭제: 본인이 작성한 신고 (회원탈퇴 시 정리용).
    // 수정: 운영자(콘솔)만.
    match /community_reports/{reportId} {
      allow read: if isSignedIn() && resource.data.reporterUid == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.reason is string
        && request.resource.data.reason.size() < 1000;
      allow delete: if isSignedIn() && resource.data.reporterUid == request.auth.uid;
      allow update: if false;
    }
  }
}
